rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /compliance/{organizationId}/{allPaths=**} {
      allow read, write: if request.auth != null 
        && request.auth.token.email_verified == true 
        && firestore.get(/databases/(default_database)/documents/users/$(request.auth.uid)).data.organizationId == organizationId;
    }
  }
}
