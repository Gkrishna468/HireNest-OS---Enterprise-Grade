rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers (Phase 3) ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') in ['gopalkrishna0046@gmail.com', 'gopal@hirenestworkforce.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrganizationMember(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().organizationId == orgId;
    }

    // --- Entity Validation Blueprints (Phase 4) ---

    function isValidRequirementPublic(data) {
      let isCreate = request.method == 'create';
      return (isCreate ? (data.keys().hasAll(['requirementId', 'clientId', 'title', 'description', 'status', 'visibility', 'ownerId', 'createdAt']) && data.keys().size() >= 8) : true) &&
             (!data.keys().hasAny(['requirementId']) || (data.requirementId is string && data.requirementId.size() <= 64)) &&
             (!data.keys().hasAny(['clientId']) || (data.clientId is string && data.clientId.size() <= 64)) &&
             (!data.keys().hasAny(['title']) || (data.title is string && data.title.size() <= 200)) &&
             (!data.keys().hasAny(['status']) || (data.status in ['DRAFT', 'PENDING_FINANCIAL_APPROVAL', 'PUBLISHED', 'CLOSED'])) &&
             (!data.keys().hasAny(['visibility']) || (data.visibility in ['INTERNAL', 'VENDOR_NETWORK'])) &&
             (!data.keys().hasAny(['ownerId']) || (data.ownerId is string && (data.ownerId == request.auth.uid || isAdmin()))) &&
             (!isCreate || data.createdAt == request.time);
    }

    match /requirements_public/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRequirementPublic(incoming()) && isOrganizationMember(incoming().clientId);
      allow update: if isValidRequirementPublic(incoming()) && (isAdmin() || (isSignedIn() && isOrganizationMember(existing().clientId))) && (
         // Admin actions
         (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly([
           'status', 'adminApproved', 'vendorVisibleBudget', 'visibility', 'updatedAt', 'financials', 'matchProcessingStatus'
         ])) ||
         // Client actions
         (isOrganizationMember(existing().clientId) && incoming().diff(existing()).affectedKeys().hasOnly([
           'title', 'description', 'skills', 'updatedAt', 'status', 'clientTargetBudget', 'experience', 'minExp', 'maxExp', 'budget', 'workMode'
         ]))
      );
    }

    // ... (rest of the rules would go here, but I'm focusing on fixing the logic leak first)
  }
}
