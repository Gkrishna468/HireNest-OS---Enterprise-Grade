rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Critical: Admin check using trusted identifiers from the token
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email_verified', false) == true && (
               request.auth.token.get('email', '').lower() == 'gopalkrishna0046@gmail.com' || 
               request.auth.token.get('email', '').lower() == 'gopal@hirenestworkforce.com'
             );
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isOrganizationMember(orgId) {
      let userData = getUserData();
      return userData != null && userData.get('organizationId', null) == orgId;
    }

    // Validation Blueprints
    function isValidOrganization(data) {
      return data.keys().hasAll(['organizationId', 'type', 'status', 'companyName']) &&
             data.organizationId is string &&
             data.type in ['vendor', 'client', 'admin', 'recruitment_agency', 'independent_vendor', 'freelancer'] &&
             data.status in ['pending_review', 'approved', 'rejected', 'active', 'pending'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'organizationId']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'client_hm', 'client_finance', 'client_recruiter', 'vendor_agency', 'vendor_recruiter', 'vendor_sourcer', 'freelancer_recruiter', 'independent_recruiter', 'independent_vendor'];
    }

    // --- Hardened Rules ---

    match /onboarding_requests/{requestId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (request.auth.token.get('email', '') == resource.data.email || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'organizationId', 'verification', 'updatedAt'])) ||
        (request.auth.uid == userId && !isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'linkedinUrl', 'identityDocs']))
      );
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOrganization(incoming());
      allow update: if (isAdmin() || (isOrganizationMember(orgId))) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'trustGrade', 'verificationLevel', 'updatedAt'])) ||
        (isOrganizationMember(orgId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'ndaUploaded', 'msaUploaded', 'businessDocsUploaded', 'updatedAt']))
      );
    }

    match /requirements_public/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Simplified for initial bootstrap
      allow update: if (isAdmin() || isOrganizationMember(existing().clientId));
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Server also writes via SDK, but client can log client events
    }

    match /quotas/{quotaId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.ownerId == request.auth.uid || isOrganizationMember(resource.data.ownerId)));
      allow write: if isAdmin();
    }

    match /risk_assessments/{riskId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
