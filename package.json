    "d3": "latest",
    "date-fns": "latest",
    "dompurify": "latest",
    "dotenv": "latest",
    "esbuild": "latest",
    "express": "latest",
    "express-async-errors": "latest",
    "express-rate-limit": "latest",
    "firebase": "latest",
    "firebase-admin": "latest",
    "googleapis": "latest",
    "helmet": "latest",
    "lucide-react": "latest",
    "mammoth": "latest",
    "motion": "latest",
    "multer": "latest",
    "pdf-parse": "latest",
