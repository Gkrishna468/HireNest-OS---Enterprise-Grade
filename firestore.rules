rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers (Phase 3) ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Critical: Admin check using trusted identifiers and database state
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') in ['gopalkrishna0046@gmail.com', 'gopal@hirenestworkforce.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrganizationMember(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().organizationId == orgId;
    }

    // --- Entity Validation Blueprints (Phase 4) ---

    function isValidOrganization(data) {
      return data.keys().hasAll(['organizationId', 'type', 'companyName', 'status', 'ownerId', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.organizationId is string && data.organizationId.size() <= 64 &&
             data.type in ['vendor', 'client', 'admin'] &&
             data.companyName is string && data.companyName.size() >= 2 && data.companyName.size() <= 200 &&
             data.status in ['pending_review', 'approved', 'rejected', 'active', 'pending'] &&
             (data.ownerId == request.auth.uid || isAdmin()) &&
             // Use request.time for temporal integrity if creating
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'organizationId', 'createdAt']) &&
             data.keys().size() <= 10 &&
             (data.uid == request.auth.uid || isAdmin()) &&
             (data.email == request.auth.token.email || isAdmin()) &&
             data.role in ['admin', 'client_hm', 'client_finance', 'client_recruiter', 'vendor_recruiter', 'vendor_sourcer'] &&
             data.organizationId is string && data.organizationId.size() <= 64 &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    function isValidRequirementPublic(data) {
      return data.keys().hasAll(['requirementId', 'clientId', 'title', 'description', 'status', 'visibility', 'ownerId', 'createdAt']) &&
             data.requirementId is string &&
             data.clientId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['DRAFT', 'PENDING_FINANCIAL_APPROVAL', 'PUBLISHED', 'CLOSED'] &&
             data.visibility in ['INTERNAL', 'VENDOR_NETWORK'] &&
             (data.ownerId == request.auth.uid || isAdmin()) &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    function isValidCandidate(data) {
      return data.keys().hasAll(['candidateId', 'vendorId', 'name', 'ownerId', 'createdAt']) &&
             data.candidateId is string &&
             data.vendorId is string &&
             data.name is string && data.name.size() <= 200 &&
             (data.ownerId == request.auth.uid || isAdmin()) &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    // --- Hardened Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'organizationId', 'updatedAt']) && isAdmin()) ||
        (request.auth.uid == userId && !isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']))
      );
    }

    match /organizations/{orgId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (isOrganizationMember(orgId) || isAdmin());
      allow create: if isSignedIn() && isValidOrganization(incoming());
      allow update: if isAdmin() || (isOrganizationMember(orgId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'ndaUploaded', 'msaUploaded', 'complianceStatus', 'updatedAt']));
    }

    match /requirements_public/{reqId} {
      allow read: if isSignedIn(); // Public requirements are visible to all authenticated users for matching
      allow create: if isSignedIn() && isValidRequirementPublic(incoming()) && isOrganizationMember(incoming().clientId);
      allow update: if (isAdmin() || (isSignedIn() && isOrganizationMember(existing().clientId))) && (
         (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'adminApproved', 'vendorVisibleBudget', 'visibility', 'updatedAt', 'financials'])) ||
         (isOrganizationMember(existing().clientId) && incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'skills', 'updatedAt']))
      );
    }

    match /requirements_private/{reqId} {
      // Identity check: Only Admin or the Client's Finance role can see these
      allow read: if isAdmin() || (isSignedIn() && isOrganizationMember(get(/databases/$(database)/documents/requirements_public/$(reqId)).data.clientId) && getUserData().role == 'client_finance');
      allow write: if isAdmin();
    }

    match /compliance_documents/{docId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (isOrganizationMember(incoming().organizationId) || isAdmin());
    }

    match /candidatePool/{candId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.vendorId == getUserData().organizationId);
      allow get: if isSignedIn() && (isAdmin() || resource.data.vendorId == getUserData().organizationId);
      allow create: if isSignedIn() && isOrganizationMember(incoming().vendorId) && isValidCandidate(incoming());
      allow update: if isAdmin() || (isSignedIn() && isOrganizationMember(existing().vendorId));
    }

    match /submissions/{subId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.vendorId == getUserData().organizationId);
      allow get: if isSignedIn() && (isAdmin() || isOrganizationMember(resource.data.vendorId) || isOrganizationMember(get(/databases/$(database)/documents/requirements_public/$(resource.data.requirementId)).data.clientId));
      allow create: if isSignedIn() && isOrganizationMember(incoming().vendorId);
      allow update: if isAdmin() || (isSignedIn() && isOrganizationMember(existing().vendorId));
    }

    match /dealRooms/{roomId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.clientId == getUserData().organizationId || resource.data.vendorId == getUserData().organizationId);
      allow get: if isSignedIn() && (isAdmin() || isOrganizationMember(resource.data.clientId) || isOrganizationMember(resource.data.vendorId));
      allow write: if isAdmin() || (isSignedIn() && (isOrganizationMember(incoming().clientId) || isOrganizationMember(incoming().vendorId)));
    }

    match /dealRooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn() && (isAdmin() || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.clientId) || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.vendorId));
      allow create: if isSignedIn() && (isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.clientId) || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.vendorId));
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && (resource.data.recipientId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.recipientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || isAdmin()) && incoming().diff(existing()).affectedKeys().hasOnly(['read', 'updatedAt']);
    }
  }
}

