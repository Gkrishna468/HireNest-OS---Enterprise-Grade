rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // GLOBAL DEFAULT DENY
    // =====================================================

    match /{document=**} {
      allow read, write: if false;
    }

    // =====================================================
    // GLOBAL HELPERS
    // =====================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function authEmail() {
      return request.auth.token.get('email', '').lower();
    }

    function authRole() {
      return request.auth.token.get('role', '') != '' ? request.auth.token.get('role', '') : (getUserData() != null ? getUserData().role : '');
    }

    function authOrgId() {
      return request.auth.token.get('organizationId', '') != '' ? request.auth.token.get('organizationId', '') : (getUserData() != null ? getUserData().organizationId : '');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // =====================================================
    // AUTHORITY
    // =====================================================

    function isHQ() {
      return isVerified() &&
      (
        authEmail() == 'gopal@hirenestworkforce.com' ||
        authEmail() == 'gopalkrishna0046@gmail.com'
      );
    }

    function isSuperAdmin() {
      return isVerified() &&
      (
        isHQ() ||
        authRole() in [
          'super_admin',
          'platform_authority'
        ]
      );
    }

    function isAdmin() {
      return isVerified() &&
      (
        isHQ() ||
        authRole() in [

          // AUTHORITY
          'admin',
          'super_admin',
          'platform_authority',
          'hq_admin',
          'ceo',

          // CLIENT
          'client_admin',
          'client_hm',
          'client_finance',
          'client_recruiter',
          'client_ops',

          // VENDOR
          'vendor_admin',
          'vendor_agency',
          'vendor_manager',
          'vendor_recruiter',
          'vendor_sourcer',

          // INDEPENDENT
          'freelancer_recruiter',
          'independent_recruiter',
          'freelancer_vendor',
          'independent_vendor',

          // AI
          'ai_agent',
          'observer',
          'system_node'
        ]
      );
    }

    function isPlatformAuthority() {
      return isAdmin() || isSuperAdmin();
    }

    // =====================================================
    // USER HELPERS
    // =====================================================

    function getUserData() {
      return exists(
        /databases/$(database)/documents/users/$(request.auth.uid)
      )
      ? get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data
      : null;
    }

    function currentOrgId() {
      return getUserData() != null ? getUserData().organizationId : authOrgId();
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSameOrg(orgId) {
      return isVerified() &&
      orgId is string &&
      (
        authOrgId() == orgId ||
        currentOrgId() == orgId
      );
    }

    function isOrganizationMember(orgId) {
      return isVerified() &&
      orgId is string &&
      currentOrgId() == orgId;
    }

    // =====================================================
    // VALIDATION HELPERS
    // =====================================================

    function isValidOrganization(data) {
      return (!data.keys().hasAny(['organizationType']) ||
          data.organizationType in [
            'client',
            'vendor',
            'independent',
            'recruitment_agency',
            'freelancer',
            'platform'
          ]) &&
        (!data.keys().hasAny(['status']) ||
          data.status in [
            'pending',
            'pending_review',
            'approved',
            'active',
            'rejected',
            'suspended'
          ]);
    }

    function isValidUser(data) {
      return (!data.keys().hasAny(['email']) ||
          data.email is string) &&
        (!data.keys().hasAny(['organizationId']) ||
          data.organizationId is string) &&
        (!data.keys().hasAny(['role']) ||
          data.role in [
            'admin',
            'super_admin',
            'platform_authority',
            'hq_admin',
            'ceo',

            // CLIENT
            'client_admin',
            'client_hm',
            'client_finance',
            'client_recruiter',
            'client_ops',

            // VENDOR
            'vendor_admin',
            'vendor_agency',
            'vendor_manager',
            'vendor_recruiter',
            'vendor_sourcer',

            // INDEPENDENT
            'freelancer_recruiter',
            'independent_recruiter',
            'freelancer_vendor',
            'independent_vendor',

            // SYSTEM
            'ai_agent',
            'observer',
            'system_node',

            // TEMP & GENERIC
            'PENDING_VERIFICATION',
            'client',
            'vendor',
            'independent'
          ]);
    }

    function isValidRequirement(data) {
      return (!data.keys().hasAny(['title']) ||
          (data.title is string &&
           data.title.size() <= 200)) &&
        (!data.keys().hasAny(['status']) ||
          data.status in [
            'DRAFT',
            'PENDING_APPROVAL',
            'PENDING_FINANCIAL_APPROVAL',
            'PUBLISHED',
            'ACTIVE',
            'ON_HOLD',
            'CLOSED',
            'REJECTED'
          ]) &&
        (!data.keys().hasAny(['visibility']) ||
          data.visibility in [
            'INTERNAL',
            'VENDOR_NETWORK'
          ]) &&
        (!data.keys().hasAny(['employmentType']) ||
          data.employmentType in [
            'CONTRACT',
            'C2H',
            'FULL_TIME',
            'PART_TIME',
            'INTERNSHIP'
          ]) &&
        (!data.keys().hasAny(['compensationModel']) ||
          data.compensationModel in [
            'LPM',
            'LPA',
            'SALARY',
            'HOURLY',
            'COMMISSION'
          ]);
    }

    function isValidCandidate(data) {
      return (!data.keys().hasAny(['matchScore']) ||
          data.matchScore is number) &&
        (!data.keys().hasAny(['pipelineStage']) ||
          data.pipelineStage in [
            'Candidate Added',
            'Duplicate Review',
            'Matched',
            'Client Submission',
            'Deal Room'
          ]);
    }

    function isValidDealRoom(data) {
      return (!data.keys().hasAny(['status']) ||
          data.status in ['ACTIVE', 'CLOSED']) &&
        (!data.keys().hasAny(['requirementId']) ||
          data.requirementId is string);
    }

    function isValidMessage(data) {
      return (!data.keys().hasAny(['text']) ||
          (data.text is string &&
           data.text.size() <= 5000)) &&
        (!data.keys().hasAny(['type']) ||
          data.type in ['text', 'system']);
    }

    // =====================================================
    // USERS
    // =====================================================

    match /users/{userId} {
      allow read:
      if isOwner(userId) || isAdmin();

      allow create:
      if isVerified() &&
         request.auth.uid == userId &&
         isValidUser(incoming()) &&
         (
           !incoming().keys().hasAny(['role']) ||
           incoming().role in ['PENDING_VERIFICATION', 'client', 'vendor', 'independent']
         );

      allow update:
      if (
           (
             isOwner(userId) && 
             isValidUser(incoming()) &&
             (
               !incoming().keys().hasAny(['role']) ||
               incoming().role == existing().role
             )
           )
           ||
           (isAdmin() && isValidUser(incoming()))
         );

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // ORGANIZATIONS
    // =====================================================

    match /organizations/{orgId} {
      allow read:
      if isAdmin() || isSameOrg(orgId);

      allow create:
      if isVerified() &&
         isValidOrganization(incoming());

      allow update:
      if isAdmin() ||
         isOrganizationMember(orgId);

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // ORGANIZATION HIERARCHY
    // =====================================================

    match /organizationHierarchy/{docId} {
      allow read:
      if isVerified();

      allow create, update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // ONBOARDING
    // =====================================================

    match /onboarding_requests/{reqId} {
      allow read:
      if isAdmin() ||
      (
        isVerified() &&
        resource.data.email == authEmail()
      );

      allow create:
      if isVerified();

      allow update, delete:
      if isAdmin();
    }

    // =====================================================
    // REQUIREMENTS PUBLIC
    // =====================================================

    match /requirements_public/{reqId} {
      allow read:
      if true;

      allow create:
      if isVerified() &&
         isValidRequirement(incoming()) &&
         incoming().clientId is string &&
         isSameOrg(incoming().clientId);

      allow update:
      if isVerified() &&
      (
        isAdmin() ||
        (
          existing().clientId is string &&
          isOrganizationMember(existing().clientId)
        )
      ) &&
      isValidRequirement(incoming());

      allow delete:
      if isAdmin();
    }

    // =====================================================
    // REQUIREMENTS PRIVATE
    // =====================================================

    match /requirements_private/{reqId} {
      allow read:
      if isAdmin() ||
      (
        isVerified() &&
        getUserData() != null &&
        getUserData().role in [
          'client_finance',
          'client_admin'
        ]
      );

      allow write:
      if isAdmin();
    }

    // =====================================================
    // JOB APPROVAL QUEUE
    // =====================================================

    match /jobApprovalQueue/{jobId} {
      allow read:
      if isPlatformAuthority();

      allow create:
      if isVerified();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // VENDOR NETWORK BROADCASTS
    // =====================================================

    match /vendorNetworkBroadcasts/{broadcastId} {
      allow read:
      if isVerified();

      allow create:
      if isPlatformAuthority();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // CANDIDATES
    // =====================================================

    match /candidatePool/{candidateId} {
      allow read:
      if isAdmin() ||
         isSameOrg(resource.data.vendorId) ||
         isSameOrg(resource.data.clientId);

      allow create:
      if isVerified() &&
         (
           isAdmin() ||
           isSameOrg(incoming().vendorId) ||
           isSameOrg(incoming().clientId)
         ) &&
         isValidCandidate(incoming());

      allow update:
      if isVerified() && (
         isAdmin() ||
         isSameOrg(existing().vendorId) ||
         isSameOrg(existing().clientId) ||
         request.resource.data.diff(resource.data).changedKeys().hasOnly([
             "fullName",
             "name",
             "updatedAt",
             "status",
             "isNameManuallyEdited",
             "candidateId"
         ])
      );

      allow delete:
      if isAdmin() ||
         isSameOrg(existing().vendorId) ||
         isSameOrg(existing().clientId);

      match /ai_matches/{matchId} {
        allow read: if isVerified();
        allow write: if isVerified();
      }
    }

    // =====================================================
    // OWNERSHIP VAULT & IDENTITY RESOLUTION
    // =====================================================

    match /ownershipVault/{claimId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update: if isVerified();
      allow delete: if isSuperAdmin();
    }

    match /ownership_claims/{claimId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update: if isVerified() && (
          // Allow system/admins or the vendor owning the claim to update it
          isAdmin() ||
          existing().vendorId == currentOrgId() ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
             "status", "updatedAt", "expiresAt", "candidateName"
          ])
      );
      allow delete: if isSuperAdmin();
    }

    match /ownership_disputes/{disputeId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /ownership_audit_log/{logId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update, delete: if false; // Immutable audit log
    }

    match /candidate_identity/{hashId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update: if isVerified();
      allow delete: if isSuperAdmin();
    }

    match /candidate_change_log/{logId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update, delete: if false;
    }

    // =====================================================
    // CANDIDATE OWNERSHIP (LEGACY / OLD)
    // =====================================================

    match /candidateOwnership/{ownershipId} {
      allow read:
      if isPlatformAuthority();

      allow create:
      if isVerified();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // CANDIDATE UPDATES
    // =====================================================

    match /candidateUpdates/{updateId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if false;

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // SUBMISSIONS
    // =====================================================

    match /submissions/{submissionId} {
      allow read:
      if isVerified() &&
      (
        isAdmin() ||
        isSameOrg(resource.data.vendorId) ||
        isSameOrg(resource.data.clientId)
      );

      allow create:
      if isVerified();

      allow update:
      if isVerified();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // DEAL ROOMS
    // =====================================================

    match /dealRooms/{roomId} {
      allow read:
      if isVerified() &&
      (
        isAdmin() ||
        request.auth.uid in resource.data.participants ||
        isSameOrg(resource.data.clientId) ||
        isSameOrg(resource.data.vendorId)
      );

      allow create:
      if isVerified() &&
         isValidDealRoom(incoming());

      allow update:
      if isVerified() &&
         isValidDealRoom(incoming());

      allow delete:
      if isAdmin();

      match /messages/{messageId} {
        allow read:
        if isVerified();

        allow create:
        if isVerified() &&
           isValidMessage(incoming());

        allow update:
        if false;

        allow delete:
        if isAdmin();
      }
    }

    // =====================================================
    // COMMUNICATION THREADS
    // =====================================================

    match /communicationThreads/{threadId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if isVerified();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // ADMIN CHANGE REQUESTS
    // =====================================================

    match /adminChangeRequests/{requestId} {
      allow read:
      if isPlatformAuthority();

      allow create:
      if isAdmin();

      allow update, delete:
      if isSuperAdmin();
    }
    
    // =====================================================
    // IMMUTABLE AUDIT LOGS
    // =====================================================

    match /immutable_audit_logs/{logId} {
      allow read:
      if isPlatformAuthority() || isAdmin();
      
      allow create, update, delete:
      if false;
    }

    // =====================================================
    // BUDGET REQUESTS
    // =====================================================

    match /budgetRequests/{requestId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if isPlatformAuthority();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // NOTIFICATIONS & EVENT LEDGER
    // =====================================================

    match /notifications/{notifId} {
      allow read:
      if isVerified() &&
      (
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );

      allow create:
      if isVerified();

      allow update:
      if isVerified();

      allow delete:
      if isSuperAdmin();
    }

    match /event_ledger/{eventId} {
      allow read: if isVerified() && (
        resource.data.recipients.hasAny([request.auth.uid, 'GLOBAL_ADMIN', 'GLOBAL_CLIENT', 'GLOBAL_VENDOR'])
      );
      allow create: if isVerified();
      allow update, delete: if false; // Immutable event ledger
    }

    // =====================================================
    // MATCH NOTIFICATIONS
    // =====================================================

    match /matchNotifications/{notifId} {
      allow read:
      if isVerified();

      allow create:
      if isPlatformAuthority();

      allow update:
      if isVerified();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // DOCUMENT VAULTS
    // =====================================================

    match /clientDocuments/{docId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    match /vendorDocuments/{docId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    match /independentDocuments/{docId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update:
      if isAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // AUDIT LOGS
    // =====================================================

    match /auditLogs/{logId} {
      allow read:
      if isAdmin();

      allow create:
      if isVerified();

      allow update, delete:
      if false;
    }

    // =====================================================
    // GOVERNANCE
    // =====================================================

    match /governance/{docId} {
      allow read:
      if isAdmin();

      allow create, update:
      if isSuperAdmin();

      allow delete:
      if isSuperAdmin();
    }

    // =====================================================
    // WORKFLOW EVENTS
    // =====================================================

    match /workflowEvents/{eventId} {
      allow read:
      if isPlatformAuthority();

      allow create:
      if isVerified();

      allow update, delete:
      if false;
    }

    // =====================================================
    // AI + ANALYTICS
    // =====================================================

    match /predictions/{predId} {
      allow read:
      if isVerified();

      allow write:
      if false;
    }

    match /trust_metrics/{nodeId} {
      allow read:
      if isVerified();

      allow write:
      if false;
    }

    match /agent_activities/{activityId} {
      allow read:
      if isVerified();

      allow create:
      if isVerified();

      allow update, delete:
      if false;
    }

    // =====================================================
    // COGNITIVE INFRASTRUCTURE & GOVERNANCE COLLECTIONS
    // =====================================================

    match /governanceEvents/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /governanceScores/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /governanceApprovalQueue/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /consensusLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /cognitiveMemoryPyramid/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /cognitiveMemoryHistory/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /cognitiveRecoveryLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /economicOptimizations/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /arbitrationLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /arbitrationLocks/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /relicIdentities/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /cognitiveSLALogs/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /federatedIntelligence/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /executiveInsights/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /infrastructureChaosLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /eventBusLogs/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /workflowStates/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /securityAlerts/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /tracingSpans/{docId} {
      allow read: if isAdmin();
      allow write: if isPlatformAuthority();
    }

    match /consentLedger/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /deletionWorkflows/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /cognitiveReplication/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /forensicReplays/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    match /workforcePods/{docId} {
      allow read: if isVerified();
      allow write: if isPlatformAuthority();
    }

    // =====================================================
    // TENANT GOVERNANCE & AI BILLING
    // =====================================================

    match /tenant_usage/{docId} {
      allow read: if isVerified() && (isPlatformAuthority() || isSameOrg(resource.data.orgId));
      allow write: if isPlatformAuthority();
    }

    match /ai_usage_logs/{docId} {
      allow read: if isVerified() && (isPlatformAuthority() || isSameOrg(resource.data.orgId));
      allow write: if isPlatformAuthority();
    }

    match /operationalEvents/{eventId} {
      allow read: if isVerified();
      allow create: if isVerified();
      allow update, delete: if false;
    }

    // =====================================================
    // EXECUTION EVENTS
    // =====================================================

    match /execution_events/{eventId} {
      allow read: if isVerified() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        isSameOrg(resource.data.orgId)
      );
      allow create: if isVerified();
      allow update, delete: if false;
    }

    // =====================================================
    // SYSTEM HEALTH
    // =====================================================

    match /systemHealth/{docId} {
      allow read:
      if isAdmin();

      allow write:
      if isSuperAdmin();
    }

    match /_health/{docId} {
      allow read:
      if true;

      allow write:
      if isSuperAdmin();
    }

    // =====================================================
    // WORKFLOW ENTITIES (INTERVIEWS, PLACEMENTS, DEAL ROOMS)
    // =====================================================

    match /dealRooms/{roomId} {
      allow read: if isVerified();
      allow write: if isVerified();
    }

    match /dealRooms/{roomId}/messages/{messageId} {
      allow read: if isVerified();
      allow write: if isVerified();
    }

    match /interviews/{interviewId} {
      allow read: if isVerified();
      allow write: if isVerified();
    }

    match /placements/{placementId} {
      allow read: if isVerified();
      allow write: if isVerified();
    }

    match /invoices/{invoiceId} {
      allow read: if isVerified();
      allow write: if isVerified();
    }

    // =====================================================
    // GLOBAL HQ OVERRIDE
    // =====================================================

    match /{document=**} {
      allow read, write:
      if isHQ();
    }
  }
}
