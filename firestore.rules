rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - The foundation of Zero Trust
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers (Pillar 3 & 4) ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmailVerified() {
      // Hardened check: recommended for production, but can be relaxed for dev
      return request.auth.token.email_verified == true;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['gopalkrishna0046@gmail.com', 'gopal@hirenestworkforce.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrganizationMember(orgId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().organizationId == orgId;
    }

    function isClient() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role.matches('client_.*');
    }

    function isVendor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role.matches('vendor_.*');
    }

    // --- Validation Blueprints (Pillar 2) ---

    function isValidOrganization(data) {
      return data.keys().hasAll(['organizationId', 'type', 'companyName', 'status', 'ownerId', 'createdAt']) &&
             data.organizationId is string &&
             data.type in ['vendor', 'client', 'admin'] &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.status in ['pending_review', 'approved', 'rejected', 'pending'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'organizationId', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role is string &&
             data.organizationId is string;
    }

    function isValidComplianceDoc(data) {
      return data.keys().hasAll(['organizationId', 'documentType', 'fileUrl', 'ownerId', 'uploadedAt', 'status']) &&
             data.organizationId is string &&
             data.documentType in ['NDA', 'MSA'] &&
             data.fileUrl is string &&
             data.ownerId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // --- Collection Rules (Pillar 8) ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'organizationId']) && isAdmin()) ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['email']) && incoming().email == existing().email) ||
        (request.auth.uid == userId && !isAdmin() && incoming().diff(existing()).affectedKeys().size() == 0)
      );
      allow delete: if isAdmin();
    }

    match /organizations/{orgId} {
      allow get: if isSignedIn() && (isOrganizationMember(orgId) || isAdmin() || !exists(/databases/$(database)/documents/users/$(request.auth.uid)));
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidOrganization(incoming());
      allow update: if isAdmin() || (isOrganizationMember(orgId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'ndaUploaded', 'msaUploaded', 'ndaUrl', 'msaUrl']));
      allow delete: if isAdmin();
    }

    match /compliance_documents/{docId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidComplianceDoc(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /requirements/{reqId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isClient();
      allow update: if isAdmin() || (isClient() && isOrganizationMember(existing().clientId));
      allow delete: if isAdmin();
    }

    match /financials/{reqId} {
      allow read: if isAdmin() || (isClient() && isOrganizationMember(get(/databases/$(database)/documents/requirements/$(reqId)).data.clientId) && getUserData().role == 'client_finance');
      allow write: if isAdmin();
    }

    match /candidatePool/{candId} {
      allow read: if isAdmin() || (isVendor() && resource.data.vendorId == getUserData().organizationId) || isClient();
      allow create: if isVendor();
      allow update: if isAdmin() || (isVendor() && resource.data.vendorId == getUserData().organizationId);
      allow delete: if isAdmin();
    }

    match /submissions/{subId} {
      allow read: if isAdmin() || isOrganizationMember(resource.data.vendorId) || isOrganizationMember(get(/databases/$(database)/documents/requirements/$(resource.data.requirementId)).data.clientId);
      allow create: if isVendor();
      allow update: if isAdmin() || isOrganizationMember(resource.data.vendorId);
      allow delete: if isAdmin();
    }

    match /dealRooms/{roomId} {
      allow read: if isAdmin() || isOrganizationMember(resource.data.clientId) || isOrganizationMember(resource.data.vendorId);
      allow create: if isAdmin() || isVendor();
      allow update: if isAdmin() || isOrganizationMember(resource.data.clientId) || isOrganizationMember(resource.data.vendorId);
      allow delete: if isAdmin();
    }

    match /dealRooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn() && (isAdmin() || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.clientId) || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.vendorId));
      allow create: if isSignedIn() && (isAdmin() || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.clientId) || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.vendorId));
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
