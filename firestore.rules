rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny is implicit, but we can be explicit. 
    // We remove the catch-all to ensure it doesn't interfere with specific match evaluations.

    // --- Hardened Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Static admin check (no DB reads) - Safe for all operations
    function isStaticAdmin() {
      return isSignedIn() && (
        request.auth.uid == '0xpXdzSQE6V92xbnCkiczPHexiU2' || 
        request.auth.uid == 'vetAu3RF2qYVmsCuB6cpEz9DDqA2' ||
        request.auth.uid == 'ZlpY4qN9BKS7n0yoMQP7LDMvvJ53' ||
        request.auth.token.get('email', '') == 'gopalkrishna0046@gmail.com' ||
        request.auth.token.get('email', '') == 'gopal@hirenestworkforce.com'
      );
    }
    
    // Dynamic admin check (with DB reads)
    function isDynamicAdmin() {
      return isStaticAdmin() || (
             isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
    }

    function isAdmin() {
      return isStaticAdmin() || isDynamicAdmin();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrganizationMember(orgId) {
      return isStaticAdmin() || (
             isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().get('organizationId', '') == orgId);
    }

    // --- Entity Validation Blueprints ---

    function isValidOrganization(data) {
      return data.keys().hasAll(['organizationId', 'type', 'companyName', 'status', 'ownerId', 'createdAt']) &&
             data.organizationId is string && data.organizationId.size() <= 128 &&
             data.type in ['vendor', 'client', 'admin'] &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.status in ['pending_review', 'approved', 'rejected', 'active', 'pending'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'organizationId', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'client_hm', 'client_finance', 'client_recruiter', 'vendor_recruiter', 'vendor_sourcer'] &&
             data.organizationId is string && data.organizationId.size() <= 128;
    }

    function isValidRequirementPublic(data) {
      return data.keys().hasAll(['requirementId', 'clientId', 'title', 'description', 'status', 'visibility', 'ownerId', 'createdAt']) &&
             data.requirementId is string &&
             data.clientId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['DRAFT', 'PENDING_FINANCIAL_APPROVAL', 'PUBLISHED', 'CLOSED'] &&
             data.visibility in ['INTERNAL', 'VENDOR_NETWORK'] &&
             data.ownerId == request.auth.uid &&
             (data.get('budget', null) == null || data.budget is map) &&
             (data.get('workMode', null) == null || data.workMode is string) &&
             (data.get('matchProcessingStatus', null) == null || data.matchProcessingStatus is string) &&
             (data.get('skills', null) == null || data.skills is list) &&
             (data.get('adminApproved', null) == null || data.adminApproved is bool);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaticAdmin() || isDynamicAdmin());
      allow list: if isStaticAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isStaticAdmin()) && isValidUser(incoming());
      allow update: if (isStaticAdmin() || isDynamicAdmin() || (isSignedIn() && request.auth.uid == userId)) && (
        isStaticAdmin() || 
        isDynamicAdmin() || 
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().size() == 0)
      );
    }

    match /organizations/{orgId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (isOrganizationMember(orgId) || isAdmin() || !exists(/databases/$(database)/documents/users/$(request.auth.uid)));
      allow create: if isSignedIn() && isValidOrganization(incoming());
      allow update: if isAdmin() || (isOrganizationMember(orgId) && incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'ndaUploaded', 'msaUploaded', 'complianceStatus', 'status']));
    }

    match /requirements_public/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRequirementPublic(incoming());
      allow update: if (isDynamicAdmin() || (isSignedIn() && isOrganizationMember(existing().clientId))) && (
         (isDynamicAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'adminApproved', 'vendorVisibleBudget', 'visibility', 'matchProcessingStatus'])) ||
         (isOrganizationMember(existing().clientId) && incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'skills', 'budget', 'workMode', 'matchProcessingStatus']))
      );
    }

    match /requirements_private/{reqId} {
      allow read: if isDynamicAdmin() || (isSignedIn() && isOrganizationMember(get(/databases/$(database)/documents/requirements_public/$(reqId)).data.clientId) && getUserData().role == 'client_finance');
      allow write: if isDynamicAdmin();
    }

    match /compliance_documents/{docId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isDynamicAdmin());
      allow create: if isSignedIn() && (isOrganizationMember(incoming().organizationId) || isDynamicAdmin());
    }

    match /candidatePool/{candId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOrganizationMember(incoming().vendorId);
      allow update: if isDynamicAdmin() || (isSignedIn() && isOrganizationMember(existing().vendorId));
    }

    match /submissions/{subId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (isDynamicAdmin() || isOrganizationMember(resource.data.vendorId) || isOrganizationMember(get(/databases/$(database)/documents/requirements_public/$(resource.data.requirementId)).data.clientId));
      allow create: if isSignedIn() && isOrganizationMember(incoming().vendorId);
      allow update: if isDynamicAdmin() || (isSignedIn() && isOrganizationMember(existing().vendorId));
    }

    match /dealRooms/{roomId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (isDynamicAdmin() || isOrganizationMember(resource.data.clientId) || isOrganizationMember(resource.data.vendorId));
      allow write: if isDynamicAdmin() || (isSignedIn() && (isOrganizationMember(incoming().clientId) || isOrganizationMember(incoming().vendorId)));
    }

    match /dealRooms/{roomId}/messages/{msgId} {
      allow read, write: if isSignedIn() && (isDynamicAdmin() || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.clientId) || isOrganizationMember(get(/databases/$(database)/documents/dealRooms/$(roomId)).data.vendorId));
    }

    match /auditLogs/{logId} {
      allow read: if isDynamicAdmin();
      allow create: if isSignedIn();
    }
  }
}
